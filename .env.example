# Exemption Request Classifier — environment variable template
# Copy this file to .env and fill in real values. Never commit .env to version control.

# ---------------------------------------------------------------------------
# Google / Gemini LLM
# Used for: chat assistant (GOOGLE_API_KEY), RAG embeddings (LLM_API_KEY)
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=your-google-api-key
LLM_API_KEY=your-google-api-key-for-embeddings
LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent

# Optional: override the Gemini model used for chat and evaluation
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EVAL_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Google Cloud Firestore (vector database)
# GOOGLE_APPLICATION_CREDENTIALS must point to a service account JSON key file
# with the Cloud Datastore User role on the GCP project.
# ---------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
FIRESTORE_DATABASE=policies
FIRESTORE_COLLECTION=policies
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ---------------------------------------------------------------------------
# TeamDynamix (TDX) Integration
# ---------------------------------------------------------------------------
TDX_API_URL=https://us.ipaas.teamdynamix.com/tdapp/app/flow/api/v1/start/<app-id>/<flow-id>?WaitForResults=true
TDX_API_KEY=your-tdx-api-key

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# Set to "development" to enable hot reload when running via `python main.py`
ENV=production

# ---------------------------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ---------------------------------------------------------------------------
# Frontend (Vite) — set in frontend/.env or frontend/.env.production
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
