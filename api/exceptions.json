                "PlanName": null,
                "ItemType": 9,
                "ItemID": 151542,
                "ItemTitle": "Cylance flagged components of Zoom on MacOS",
                "ReferenceID": null,
                "Body": "Changed Status from <b>Customer Responded</b> to <b>Resolved</b>.<br /><br />Hi Mike,\r\n\r\nI sent you a dropbox with the latest version of cylance.\r\n\r\nYou might want to look at page 88 of this for some install options:\r\n\r\nhttps://support.viperline.com/uploads/CylancePROTECT_Admin_Guide_2.1_rev34.pdf\r\n\r\n&quot;VenueZone=NSS&quot; will put you in the correct location.  \r\n\r\nAnd I think to re-install you might need to uninstall it first.  Not 100% sure though.\r\n\r\nLet us know if you need anything else.\r\n\r\nEric",
                "UpdateType": 2,
                "NotifiedList": "Michael Porter <mike@UDel.Edu>",
                "IsPrivate": true,
                "IsParent": false,
                "RepliesCount": 0,
                "ILike": false,
