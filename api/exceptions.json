                "HasAttachment": false
            },
            {
                "ID": 423563,
                "CreatedUid": "066b4b65-3fa5-e911-a81d-000d3a1808ae",
                "CreatedRefID": 50455,
                "CreatedFullName": "Tyrone Smith",
                "CreatedFirstName": "Tyrone",
                "CreatedLastName": "Smith",
                "CreatedByPicPath": null,
                "CreatedDate": "2021-04-22T13:16:36.18Z",
                "LastUpdatedDate": "2021-04-22T16:55:01.417Z",
                "ProjectID": 0,
